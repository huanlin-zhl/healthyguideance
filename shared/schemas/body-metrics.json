{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "body-metrics.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "measured_at":                 { "type": "string", "description": "测量时间，ISO 8601 不带时区" },
    "weight_kg":                   { "type": "number", "description": "体重，kg" },
    "bmi":                         { "type": ["number", "null"], "description": "BMI" },
    "body_fat_pct":                { "type": ["number", "null"], "description": "体脂率，%" },
    "skeletal_muscle_kg":          { "type": ["number", "null"], "description": "骨骼肌量，kg" },
    "visceral_fat_level":          { "type": ["number", "null"], "description": "内脏脂肪等级" },
    "limb_skeletal_muscle_index":  { "type": ["number", "null"], "description": "四肢骨骼肌指数，kg/m²" },
    "waist_hip_ratio_est":         { "type": ["number", "null"], "description": "推测腰臀比" },
    "body_age":                    { "type": ["integer", "null"], "description": "身体年龄，岁" },
    "heart_rate_bpm":              { "type": ["integer", "null"], "description": "心率，bpm" },
    "bmr_kcal":                    { "type": ["integer", "null"], "description": "基础代谢率，千卡/日" },
    "water_pct":                   { "type": ["number", "null"], "description": "水分率，%" },
    "bone_salt_kg":                { "type": ["number", "null"], "description": "骨盐量，kg" },
    "protein_pct":                 { "type": ["number", "null"], "description": "蛋白质，%" },
    "lean_body_mass_kg":           { "type": ["number", "null"], "description": "去脂体重，kg" },
    "body_type":                   { "type": ["string", "null"], "description": "身体类型原文，如 肥胖型 / 标准型" },
    "body_shape":                  { "type": ["string", "null"], "description": "身体形态原文，如 苹果型 / 匀称型" },
    "muscle_distribution": {
      "type": ["object", "null"],
      "description": "分肢骨骼肌量，kg；截图未提供则整体填 null",
      "additionalProperties": false,
      "properties": {
        "right_arm": { "type": "number", "description": "右上肢" },
        "left_arm":  { "type": "number", "description": "左上肢" },
        "trunk":     { "type": "number", "description": "躯干" },
        "right_leg": { "type": "number", "description": "右下肢" },
        "left_leg":  { "type": "number", "description": "左下肢" }
      },
      "required": ["right_arm", "left_arm", "trunk", "right_leg", "left_leg"]
    },
    "body_score":       { "type": ["integer", "null"], "description": "身体得分（如华为的 71 分）" },
    "app_summary_text": { "type": ["string", "null"], "description": "体脂秤 app 自带的中文小结，原文完整抽取；仅存档不参与分析" },
    "source_app":       { "type": ["string", "null"], "description": "数据来源 app" },
    "device":           { "type": ["string", "null"], "description": "设备型号" }
  },
  "required": [
    "measured_at", "weight_kg",
    "bmi", "body_fat_pct", "skeletal_muscle_kg", "visceral_fat_level",
    "limb_skeletal_muscle_index", "waist_hip_ratio_est",
    "body_age", "heart_rate_bpm", "bmr_kcal",
    "water_pct", "bone_salt_kg", "protein_pct", "lean_body_mass_kg",
    "body_type", "body_shape", "muscle_distribution",
    "body_score", "app_summary_text",
    "source_app", "device"
  ]
}
