{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "body-metrics.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "measured_at":        { "type": "string", "description": "测量时间，ISO 8601 不带时区" },
    "weight_kg":          { "type": "number", "description": "体重，kg" },
    "bmi":                { "type": ["number", "null"], "description": "BMI" },
    "body_fat_pct":       { "type": ["number", "null"], "description": "体脂率，%" },
    "visceral_fat_level": { "type": ["number", "null"], "description": "内脏脂肪等级" },
    "skeletal_muscle_kg": { "type": ["number", "null"], "description": "骨骼肌量，kg" },
    "heart_rate_bpm":     { "type": ["integer", "null"], "description": "静息心率，bpm" }
  },
  "required": [
    "measured_at", "weight_kg",
    "bmi", "body_fat_pct", "visceral_fat_level", "skeletal_muscle_kg",
    "heart_rate_bpm"
  ]
}
