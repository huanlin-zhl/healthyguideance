{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workout.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "date_time":         { "type": "string", "description": "运动开始时间，ISO 8601 不带时区" },
    "sport_type":        { "type": "string", "description": "运动类型原文，如 户外骑行 / 泳池游泳 / 自由训练 / 跑步" },
    "duration_text":     { "type": "string", "description": "运动总时长原文，如 01:34:26 / 46分5秒 / 1:37:12" },
    "calories_text":     { "type": "string", "description": "消耗热量原文，如 861 千卡 / 406 kcal" },
    "avg_heart_rate":    { "type": ["integer", "null"], "description": "平均心率，bpm（纯数字，单位固定）" },
    "max_heart_rate":    { "type": ["integer", "null"], "description": "最大心率，bpm（纯数字，单位固定）" },
    "hr_zones": {
      "type": ["object", "null"],
      "description": "心率区间分布，原文字符串（含数字+单位，如 '29 分钟'）；截图未提供则整体填 null",
      "additionalProperties": false,
      "properties": {
        "extreme":   { "type": "string", "description": "极限，如 '0 分钟'" },
        "anaerobic": { "type": "string", "description": "无氧耐力，如 '0 分钟'" },
        "aerobic":   { "type": "string", "description": "有氧耐力，如 '6 分钟'" },
        "fat_burn":  { "type": "string", "description": "燃脂，如 '29 分钟'" },
        "warmup":    { "type": "string", "description": "热身，如 '10 分钟'" }
      },
      "required": ["extreme", "anaerobic", "aerobic", "fat_burn", "warmup"]
    },
    "distance_text":     { "type": ["string", "null"], "description": "距离原文，如 30.85 公里 / 1000 米" },
    "avg_pace_or_speed": { "type": ["string", "null"], "description": "配速或平均速度原文，如 5'46\"/km 或 19.60 km/h" }
  },
  "required": [
    "date_time", "sport_type", "duration_text", "calories_text",
    "avg_heart_rate", "max_heart_rate", "hr_zones",
    "distance_text", "avg_pace_or_speed"
  ]
}
