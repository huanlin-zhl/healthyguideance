<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HealthyGuidance.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HealthyGuidance.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="HealthyGuidance - 截图解析测试">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24" RowDefinitions="Auto,Auto,*,Auto,*">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <Button x:Name="PickAndParseButton" Content="选择截图并解析" Click="PickAndParseButton_Click" />
            <Button x:Name="ReloadPromptButton" Content="重新加载 Prompt" Click="ReloadPromptButton_Click" />
            <Button x:Name="SettingsButton" Content="⚙ 设置" Click="SettingsButton_Click" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Text="就绪" />
        </StackPanel>

        <Expander Grid.Row="1"
                  Margin="0,16,0,0"
                  HorizontalAlignment="Stretch"
                  IsExpanded="False">
            <Expander.Header>
                <TextBlock x:Name="PromptHeader" Text="System Prompt（点击展开）" FontWeight="SemiBold" />
            </Expander.Header>
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          MaxHeight="300">
                <TextBox x:Name="PromptBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas"
                         FontSize="12" />
            </ScrollViewer>
        </Expander>

        <TextBlock Grid.Row="3" Margin="0,16,0,8" FontWeight="SemiBold" Text="返回 JSON：" />

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <TextBox x:Name="ResultBox"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas"
                     FontSize="13"
                     MinHeight="300" />
        </ScrollViewer>
    </Grid>
</Window>
