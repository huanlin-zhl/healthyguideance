<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HealthyGuidance.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="HealthyGuidance - 设置">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Azure AI Foundry 配置"
                   FontSize="18"
                   FontWeight="SemiBold" />

        <StackPanel Grid.Row="1" Spacing="4">
            <TextBlock Text="Endpoint" FontWeight="SemiBold" />
            <TextBlock Text="格式：https://&lt;resource&gt;.services.ai.azure.com/openai/v1"
                       Opacity="0.6"
                       FontSize="12" />
            <TextBox x:Name="EndpointBox" PlaceholderText="https://...services.ai.azure.com/openai/v1" />
        </StackPanel>

        <StackPanel Grid.Row="2" Spacing="4">
            <TextBlock Text="Deployment Name" FontWeight="SemiBold" />
            <TextBlock Text="如 gpt-4o-mini" Opacity="0.6" FontSize="12" />
            <TextBox x:Name="DeploymentBox" PlaceholderText="gpt-4o-mini" />
        </StackPanel>

        <StackPanel Grid.Row="3" Spacing="4">
            <TextBlock Text="API Key" FontWeight="SemiBold" />
            <TextBlock Text="存储位置：%LocalAppData%\HealthyGuidance\config\secrets.dat（DPAPI 加密）"
                       Opacity="0.6"
                       FontSize="12" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <PasswordBox Grid.Column="0"
                             x:Name="ApiKeyBox"
                             PlaceholderText="粘贴 API key" />
                <ToggleButton Grid.Column="1"
                              x:Name="ShowKeyToggle"
                              Content="显示"
                              Checked="ShowKeyToggle_Checked"
                              Unchecked="ShowKeyToggle_Unchecked" />
            </Grid>
            <TextBlock x:Name="MaskedKeyText"
                       Opacity="0.6"
                       FontSize="12"
                       Text="" />
        </StackPanel>

        <TextBlock Grid.Row="5"
                   x:Name="StatusText"
                   Text=""
                   Opacity="0.8" />

        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="取消" Click="CancelButton_Click" />
            <Button x:Name="SaveButton"
                    Content="保存"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
